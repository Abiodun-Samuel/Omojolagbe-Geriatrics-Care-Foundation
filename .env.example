# Copy this file to .env and fill in the value.

# Web3Forms access key. This makes every form on the site send real emails.
#
# 1. Go to https://web3forms.com and enter the inbox you want submissions in.
# 2. They email you an access key. Paste it below.
# 3. Restart the dev server, or rebuild for production.
#
# Without this key the forms still work: they fall back to opening the
# visitor's own email app with the message pre-filled and addressed to you.
VITE_WEB3FORMS_KEY=
